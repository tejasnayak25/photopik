# Example env values — copy to .env.local and fill
GOOGLE_SERVICE_ACCOUNT_JSON="/path/to/service-account.json"
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-auth-domain
FIREBASE_PROJECT_ID=your-project-id
HF_SPACE_URL=https://your-hf-space.app

# Shared parent folder ID in Google Drive (service account email must have Editor access)
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-gdrive-shared-parent-folder-id

# Static API secret key for uploads (or leave empty to only use Firebase Auth RBAC)
ADMIN_UPLOAD_SECRET=your-secure-upload-secret-key

# --- PERSONAL DRIVE FLOW (Optional) ---
# If you are using a personal Google Account (which does not have Shared Drives),
# configure these variables to authenticate as yourself and use your own storage quota.
GOOGLE_REFRESH_TOKEN=your-oauth2-refresh-token
GOOGLE_CLIENT_ID=your-oauth2-client-id
GOOGLE_CLIENT_SECRET=your-oauth2-client-secret

